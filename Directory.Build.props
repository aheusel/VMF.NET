<Project>
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <LangVersion>latest</LangVersion>

    <!-- Package metadata -->
    <Authors>VMF.NET Contributors</Authors>
    <Description>VMF.NET — Visual Modeling Framework for .NET</Description>
    <PackageLicenseExpression>Apache-2.0</PackageLicenseExpression>
    <RepositoryType>git</RepositoryType>
    <RepositoryUrl>https://github.com/aheusel/VMF.NET</RepositoryUrl>
    <PackageTags>vmf;modeling;code-generation;source-generator</PackageTags>
  </PropertyGroup>
</Project>
